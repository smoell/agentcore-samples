{
	"name": "agentcore-gateway-mcp-inspector",
	"version": "0.21.1",
	"description": "AgentCore Gateway MCP Inspector",
	"type": "module",
	"files": [
		"client/bin",
		"client/dist",
		"server/build",
		"server/static"
	],
	"workspaces": [
		"client",
		"server"
	],
	"scripts": {
		"build": "npm run build-server && npm run build-client",
		"build-server": "cd server && npm run build",
		"build-client": "cd client && npm run build",
		"clean": "rimraf ./node_modules ./client/node_modules ./build ./client/dist ./server/build ./package-lock.json && npm install",
		"dev": "node client/bin/start.js --dev",
		"dev:windows": "node client/bin/start.js --dev",
		"start": "node client/bin/start.js",
		"start-server": "cd server && npm run start",
		"start-client": "cd client && npm run preview",
		"test": "npm run prettier-check && cd client && npm test",
		"prettier-fix": "prettier --write .",
		"prettier-check": "prettier --check .",
		"lint": "prettier --check . && cd client && npm run lint",
		"prepare": "husky && npm run build"
	},
	"dependencies": {
		"agentcore-gateway-mcp-inspector-client": "^0.21.1",
		"agentcore-gateway-mcp-inspector-server": "^0.21.1",
		"@modelcontextprotocol/sdk": "^1.25.2",
		"concurrently": "^9.2.0",
		"node-fetch": "^3.3.2",
		"ts-node": "^10.9.2",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@types/node": "^22.17.0",
		"husky": "^9.1.7",
		"prettier": "^3.7.1",
		"rimraf": "^6.0.1",
		"typescript": "^5.4.2"
	},
	"overrides": {
		"get-intrinsic": "1.3.0"
	},
	"engines": {
		"node": ">=22.7.5"
	},
	"lint-staged": {
		"**/*.{js,ts,jsx,tsx,json,md}": [
			"prettier --write"
		]
	}
}
