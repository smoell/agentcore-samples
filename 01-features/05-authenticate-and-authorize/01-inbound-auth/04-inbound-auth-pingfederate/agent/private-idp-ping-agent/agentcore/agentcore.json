      "networkMode": "PUBLIC",
      "protocol": "HTTP"
    }
  ],
  "memories": [],
  "credentials": [
    {
      "authorizerType": "OAuthCredentialProvider",
      "name": "ping-private-idp",
      "discoveryUrl": "https://example.com/.well-known/openid-configuration",
      "scopes": [
        "openid"
      ],
      "vendor": "CustomOauth2",
      "usage": "outbound"
    }
  ],
  "evaluators": [],
  "onlineEvalConfigs": [],
