{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "PrivateIdpPingAgent",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "PrivateIdpPingAgent"
  },
