# EKS Travel Agent deployment configuration
# Copy this file to config.env and edit before running deploy.sh

# AWS region for all resources
AWS_REGION=us-east-1

# EKS cluster name (created by eksctl)
CLUSTER_NAME=eks-strands-agents-demo

# Kubernetes service name and ECR repository name
SERVICE_NAME=strands-agents-travel

# CloudWatch log group and stream for OpenTelemetry logs
LOG_GROUP_NAME=/strands-agents/travel
LOG_STREAM_NAME=agent-logs

# CloudWatch metrics namespace
METRIC_NAMESPACE=StrandsAgents/Travel

# Local port for kubectl port-forward testing
LOCAL_PORT=8080
SERVICE_PORT=80
