# Datadog credentials — get from https://app.datadoghq.com → Organization Settings → API Keys
DD_API_KEY=your-datadog-api-key

# Datadog site (US1: datadoghq.com, EU1: datadoghq.eu, US3: us3.datadoghq.com, etc.)
DD_SITE=datadoghq.com

# ML app name visible in Datadog LLM Observability
OTEL_SERVICE_NAME=agentcore-travel-agent

# AWS region
AWS_DEFAULT_REGION=us-east-1
