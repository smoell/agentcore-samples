# OpenLIT OTLP endpoint — must be accessible from AgentCore Runtime
# Docker on EC2: http://<ec2-public-ip>:4318
# Kubernetes LoadBalancer: http://<lb-external-ip>:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://your-openlit-host:4318

# Service name visible in OpenLIT dashboard
OTEL_SERVICE_NAME=agentcore-travel-agent

# AWS region
AWS_DEFAULT_REGION=us-east-1
