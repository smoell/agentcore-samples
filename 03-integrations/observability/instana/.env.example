# Instana credentials — get agent key from Instana sidebar → Agents & Collectors → Linux one-liner
INSTANA_KEY=your-instana-agent-key

# Instana OTLP HTTP endpoint (port 4318)
# Find via: Instana sidebar → About Instana → Instance Region → select HTTP OTLP endpoint
# Example: https://otlp-blue-saas.instana.io:4318
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-instana-endpoint:4318

# Service name visible in Instana
OTEL_SERVICE_NAME=agentcore-travel-agent

# AWS region
AWS_DEFAULT_REGION=us-east-1
