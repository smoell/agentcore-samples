# Honeycomb credentials — get from https://ui.honeycomb.io → Environment Settings → API Keys
HONEYCOMB_API_KEY=your-honeycomb-api-key

# Dataset name in Honeycomb where traces appear
HONEYCOMB_DATASET=llmobs

# Service name visible in Honeycomb
OTEL_SERVICE_NAME=agentcore-travel-agent

# AWS region
AWS_DEFAULT_REGION=us-east-1
