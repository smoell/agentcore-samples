    "aws-cdk": "^2.1126.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@aws/agentcore-cdk": "^0.1.0-alpha.19",
    "aws-cdk-lib": "^2.248.0",
