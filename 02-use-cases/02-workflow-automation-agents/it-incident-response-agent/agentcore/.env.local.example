# agentcore/.env.local.example — Runtime env vars for `agentcore dev`
#
# Copy to .env.local and fill in. This file is passed into the dev container
# when you run `agentcore dev`. It contains ONLY vars that the agent Python
# code reads at runtime (via os.environ).
#
# For deploy-time config (account, region, CDK flags), use ITIncidentAgent/.env
# For local dev runtime vars, use THIS file (agentcore/.env.local)

# ─── Agent Model ────────────────────────────────────────────────────
# The Bedrock model the agent uses. Must be enabled in your Bedrock console.
AGENT_MODEL_ID=us.anthropic.claude-sonnet-4-6
# Cheaper model for LOW priority tickets (cost routing)
FAST_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ─── Gateway Auth (Boundary 2: Agent → Gateway) ────────────────────
# How the agent authenticates to the AgentCore Gateway.
# AWS_IAM: uses the container's IAM credentials (default, zero config)
# CUSTOM_JWT: uses @requires_access_token to fetch an M2M token
GATEWAY_AUTH_MODE=AWS_IAM
# --- Uncomment for CUSTOM_JWT mode ---
# GATEWAY_OAUTH_PROVIDER_NAME=auth0-m2m
# GATEWAY_OAUTH_AUDIENCE=https://it-incident-response/api

# ─── Jira Auth (Boundary 3: Agent → Atlassian MCP, optional) ───────
# When set, the agent connects to the Atlassian Remote MCP server.
# Auth: USER_FEDERATION (3LO) — agent acts as a specific Jira user.
# Leave commented out to use the DDB mock-ticket path.
# JIRA_MCP_URL=https://mcp.atlassian.com/v1/sse
# JIRA_OAUTH_PROVIDER_NAME=your-stack-name_jira_3lo
# JIRA_SITE_URL=https://your-tenant.atlassian.net
# JIRA_PROJECT_KEY=INC

# ─── Guardrail (optional) ──────────────────────────────────────────
# Only needed if you want guardrails active during local dev.
# GUARDRAIL_ID=your-guardrail-id
# GUARDRAIL_VERSION=DRAFT

# ─── EventBridge (optional) ─────────────────────────────────────────
# EVENT_BUS_NAME=it-incident-agent-events
