# IT Incident Response Agent — Deploy-Time Configuration
#
# Copy to .env (or .env.local) and fill in. Both are gitignored.
# This file controls CDK synthesis and resource creation (`agentcore deploy`).
#
# For LOCAL DEV runtime vars (what the agent container reads during `agentcore dev`),
# see: agentcore/.env.local.example
#
# Summary:
#   .env / .env.local          → agentcore deploy (CDK synthesis)
#   agentcore/.env.local       → agentcore dev (container runtime)

# ─── AWS Account ────────────────────────────────────────────────────
AWS_REGION=us-west-2
CDK_DEFAULT_ACCOUNT=123456789012

# ─── Agent Model ────────────────────────────────────────────────────
# Primary model (used for MEDIUM/HIGH/CRITICAL tickets)
AGENT_MODEL_ID=us.anthropic.claude-sonnet-4-6
# Fast/cheap model (used for LOW priority tickets)
FAST_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# ─── Knowledge Base (auto-created if empty) ────────────────────────
# Leave empty to auto-create a KB with S3 Vectors (recommended).
# Set to a pre-existing KB ID to use an external Knowledge Base instead.
# Set SKIP_KB=true to disable the KB tool entirely.
KB_ID=
SKIP_KB=

# ─── Guardrail (auto-created if empty) ─────────────────────────────
# Pre-created Bedrock Guardrail ID. Leave empty to auto-create one.
GUARDRAIL_ID=
GUARDRAIL_VERSION=DRAFT

# ─── EventBridge ────────────────────────────────────────────────────
# Custom event bus name. Leave empty to auto-create 'it-incident-agent-events'.
EVENT_BUS_NAME=

# ─── Gateway Auth (Boundary 2: Agent → Gateway) ────────────────────
# Controls how the agent authenticates when calling the AgentCore Gateway.
# AWS_IAM (default, zero setup): agent signs MCP requests with SigV4
# CUSTOM_JWT: agent fetches M2M OAuth token via AgentCore Identity
GATEWAY_AUTH_MODE=AWS_IAM

# --- CUSTOM_JWT only (uncomment if GATEWAY_AUTH_MODE=CUSTOM_JWT) ---
# GATEWAY_OAUTH_PROVIDER_NAME=auth0-m2m
# GATEWAY_OAUTH_AUDIENCE=https://it-incident-response/api

# ─── Infrastructure ─────────────────────────────────────────────────
# Set to true for dev (destroys DDB data on stack delete)
DESTROY_ON_DELETE=true

# ─── Jira Auth (Boundary 3: Agent → Atlassian MCP, optional) ───────
# When configured, the agent connects to the Atlassian Remote MCP server
# to read Jira issues, add comments, and transition issue status.
# Auth: USER_FEDERATION (OAuth 2.0 3LO) — agent acts as a real Jira user.
# Leave all JIRA_* vars empty to use the DDB mock-ticket path instead.
#
# Pre-setup:
#   1. Create an OAuth 2.0 (3LO) app at developer.atlassian.com
#      Add scopes: read:me, read:jira-user, read:jira-work, write:jira-work, offline_access
#   2. After first deploy, add the callback URL from stack outputs to
#      your Atlassian app's allowed callback URLs.
#   3. First invocation requires one-time user consent (check runtime logs).
# ----------------------------------------------------------------------------
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
JIRA_SITE_URL=
JIRA_PROJECT_KEY=INC
