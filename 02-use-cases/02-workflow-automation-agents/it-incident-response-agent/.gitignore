# Override root .gitignore exclusion of lib/ — CDK source lives in agentcore/cdk/lib/
!agentcore/cdk/lib/
!agentcore/cdk/lib/**

# Python
*.py[cod]
*$py.class
*.egg
*.egg-info/
__pycache__/
.Python
.venv/
venv/
build/
dist/

# Testing / Coverage
.coverage
.pytest_cache/
htmlcov/

# Environment / Secrets
.env
.env.local
.env.*.local
.env.bak
*.key
*.pem

# IDE
.idea/
.vscode/
*.swo
*.swp
*~

# Kiro (AI coding assistant context)
.kiro/
AGENTS.md

# OS
.DS_Store
Desktop.ini
Thumbs.db

# Logs
*.log

# CDK
agentcore/cdk/cdk.out/
agentcore/cdk/node_modules/
cdk.out/

# AgentCore CLI
agentcore/.cli/deployed-state.json
agentcore/aws-targets.json

# Developer-only files (not for consumers)
DEPLOY_TEST.sh
deploy_output.log
.envrc
.standards/
.hooks/

# Docs build artifacts
docs/diagrams
